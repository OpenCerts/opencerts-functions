{
  "name": "function-email",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "create-domain:verify": "cd ./src/verify && sls create_domain",
    "dev": "npm-run-all --parallel dev:*",
    "dev:email": "cd ./src/email && sls offline start",
    "dev:storage": "cd ./src/storage && sls offline start",
    "dev:verify": "cd ./src/verify && sls offline start",
    "deploy": "npm-run-all --sequential \"deploy:* -- {@}\" --",
    "deploy:email": "cd ./src/email && sls deploy",
    "deploy:storage": "cd ./src/storage && sls deploy",
    "deploy:verify": "cd ./src/verify && sls deploy",
    "s3-local-setup": "cd ./src/storage && sls plugin install --name serverless-s3-local",
    "sls-config-check": "npm-run-all --sequential sls-config-check::*",
    "sls-config-check:email": "cd ./src/email && sls print",
    "sls-config-check:storage": "cd ./src/storage && sls print",
    "sls-config-check:verify": "cd ./src/verify && sls print",
    "test": "jest --testPathPattern=src",
    "test-watch": "jest --watch",
    "e2etest": "jest --testPathPattern=test/e2e",
    "integration:local": "IS_OFFLINE=true jest --testPathPattern=test/integration",
    "e2e:local": "IS_OFFLINE=true jest --testPathPattern=test/e2e",
    "lint": "eslint . --ext .js --max-warnings 0",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "keywords": [],
  "author": "Raymond Yeh <yehjxraymond@gmail.com> (http://geek.sg)",
  "license": "ISC",
  "dependencies": {
    "@govtechsg/oa-encryption": "^1.3.5",
    "@govtechsg/open-attestation": "^6.9.5",
    "@govtechsg/opencerts-verify": "^3.1.3",
    "@middy/core": "^5.1.0",
    "@middy/http-cors": "^5.1.0",
    "aws-sdk": "^2.1691.0",
    "lodash": "^4.17.21",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.16",
    "serverless": "^3.39.0",
    "serverless-http": "^3.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "copy-webpack-plugin": "^12.0.2",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^28.9.0",
    "eslint-plugin-prettier": "^5.1.0",
    "file-loader": "^6.2.0",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "raw-loader": "^4.0.1",
    "serverless-domain-manager": "^7.3.8",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-offline": "^13.8.1",
    "serverless-plugin-typescript": "^2.1.5",
    "serverless-s3-local": "^0.8.1",
    "serverless-s3-remover": "^0.6.0",
    "serverless-webpack": "^5.14.1",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2",
    "webpack": "^5.97.1"
  },
  "prettier": {
    "trailingComma": "none"
  }
}
